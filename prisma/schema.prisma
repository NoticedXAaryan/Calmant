generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

model User {
  id                     String                  @id @default(cuid())
  email                  String                  @unique
  name                   String?
  emailVerified          Boolean                 @default(false)
  image                  String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  onboarded              Boolean                 @default(false)
  tasks                  Task[]
  habits                 Habit[]
  memories               AgentMemory[]
  ntfyTopic              String?
  sessions               Session[]
  accounts               Account[]
  integrationConnections IntegrationConnection[]
  notificationDeliveries NotificationDelivery[]
  alertPolicies          AlertPolicy[]
  agentRuns              AgentRun[]
  delegatedTasks         DelegatedTask[]
  auditEvents            AuditEvent[]
  artifacts              Artifact[]
  watchers               Watcher[]
  approvalRequests       ApprovalRequest[]
  inAppNotifications     InAppNotification[]
  events                 AgentEvent[]
  goals                  Goal[]
  opportunities          Opportunity[]
  projectCells           ProjectCell[]
  reports                Report[]
  memoryRecords          MemoryRecord[]
}

model Task {
  id            String     @id @default(cuid())
  userId        String
  title         String
  description   String?
  deadline      DateTime
  estimatedMins Int?
  actualMins    Int?
  priority      Float      @default(0.5)
  entropyScore  Float      @default(0.0)
  snoozeCount   Int        @default(0)
  lastAlertedAt DateTime?
  status        TaskStatus @default(PENDING)
  calEventId    String?
  createdAt     DateTime   @default(now())
  completedAt   DateTime?
  subtasks      Subtask[]
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Subtask {
  id     String     @id @default(cuid())
  taskId String
  title  String
  status TaskStatus @default(PENDING)
  task   Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Habit {
  id          String            @id @default(cuid())
  userId      String
  name        String
  frequency   HabitFrequency
  streak      Int               @default(0)
  completions HabitCompletion[]
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model HabitCompletion {
  id      String   @id @default(cuid())
  habitId String
  date    DateTime
  habit   Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
}

model AgentMemory {
  id          String    @id @default(cuid())
  userId      String
  fact        String
  category    String // behavior | preference | pattern | alert
  confidence  Float     @default(0.8)
  status      String    @default("active") // pending_review | active | rejected
  sourceRunId String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceRun   AgentRun? @relation(fields: [sourceRunId], references: [id], onDelete: SetNull)
}

model Session {
  id        String   @id
  userId    String
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  SKIPPED
  DEFERRED
  DRAFT
}

enum HabitFrequency {
  DAILY
  WEEKLY
  CUSTOM
}

model IntegrationConnection {
  id            String    @id @default(cuid())
  userId        String
  provider      String // email | google_calendar | telegram | whatsapp | ntfy
  status        String // not_configured | configured | connected | live_verified | degraded
  externalId    String?
  accessToken   String?
  refreshToken  String?
  expiresAt     DateTime?
  metadata      Json?
  lastCheckedAt DateTime?
  lastSuccessAt DateTime?
  lastFailureAt DateTime?
  lastError     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

model NotificationDelivery {
  id           String    @id @default(cuid())
  userId       String
  taskId       String?
  channel      String // in_app | email | telegram | whatsapp | ntfy
  intent       String // test | task_created | warm | hot | critical | calendar_conflict | recovery
  providerId   String?
  status       String // queued | sent | delivered | failed | bounced | opened | clicked
  payload      Json?
  error        String?
  scheduledFor DateTime?
  sentAt       DateTime?
  deliveredAt  DateTime?
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AlertPolicy {
  id             String   @id @default(cuid())
  userId         String
  channel        String
  enabled        Boolean  @default(true)
  minEntropy     Float?
  quietHours     Json?
  escalationRank Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BackgroundJob {
  id          String    @id @default(cuid())
  name        String
  payload     Json?
  runAt       DateTime  @default(now())
  status      String    @default("queued") // queued | processing | completed | failed
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  lastError   String?
  lockedAt    DateTime?
  lockedBy    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, runAt])
}

model AgentRun {
  id               String         @id @default(cuid())
  userId           String
  prompt           String
  response         String?
  status           String         @default("running") // running | completed | failed
  modelId          String?
  promptTokens     Int?
  completionTokens Int?
  contextSnapshot  Json?
  classification   Json?
  plan             Json?
  currentPhase     String?
  channel          String?
  lastError        String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectCellId    String?
  projectTaskId    String?
  projectCell      ProjectCell?   @relation(fields: [projectCellId], references: [id], onDelete: SetNull)
  projectTask      ProjectTask?   @relation(fields: [projectTaskId], references: [id], onDelete: SetNull)
  toolCalls        ToolCall[]
  memories         AgentMemory[]
  events           AgentEvent[]
  skillRuns        SkillRun[]
  qaResults        QaResult[]
  memoryRecords    MemoryRecord[]
}

model ToolCall {
  id               String    @id @default(cuid())
  runId            String
  toolName         String
  args             Json
  result           Json?
  status           String    @default("pending") // pending | approved | completed | failed | rejected
  riskLevel        String?
  approvalRequired Boolean   @default(false)
  durationMs       Int?
  error            String?
  createdAt        DateTime  @default(now())
  startedAt        DateTime?
  completedAt      DateTime?
  run              AgentRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
}

model DelegatedTask {
  id        String   @id @default(cuid())
  userId    String
  title     String
  context   Json?
  status    String   @default("active") // active | paused | completed | cancelled
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ApprovalRequest {
  id            String    @id @default(cuid())
  userId        String
  type          String // "email", "post", "form_submission", "calendar_event"
  title         String
  description   String
  payload       Json // The full action payload to execute on approval
  status        String    @default("pending") // pending, approved, rejected, executed
  agentRunId    String? // Link to the agent run that created this
  createdAt     DateTime  @default(now())
  reviewedAt    DateTime?
  executedAt    DateTime?
  projectCellId String?

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectCell ProjectCell? @relation(fields: [projectCellId], references: [id], onDelete: Cascade)
}

model InAppNotification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  taskId    String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditEvent {
  id         String   @id @default(cuid())
  userId     String
  action     String
  targetType String?
  targetId   String?
  details    Json?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Artifact {
  id              String       @id @default(cuid())
  userId          String
  delegatedTaskId String?
  agentRunId      String?
  toolCallId      String?
  type            String // screenshot | note | document | html_snapshot | form_data
  title           String
  description     String?
  filePath        String? // path in artifact volume (for binary files)
  content         String? // for text-based artifacts (notes, documents)
  metadata        Json?
  createdAt       DateTime     @default(now())
  projectCellId   String?
  projectTaskId   String?
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectCell     ProjectCell? @relation(fields: [projectCellId], references: [id], onDelete: Cascade)
  projectTask     ProjectTask? @relation(fields: [projectTaskId], references: [id], onDelete: Cascade)

  @@index([userId, delegatedTaskId])
  @@index([userId, createdAt])
  @@index([toolCallId])
}

model Watcher {
  id              String         @id @default(cuid())
  userId          String
  name            String
  description     String?
  type            String // schedule | webhook | event | database
  target          String // e.g. URL, table name, or specific cron expression
  condition       Json? // condition to evaluate before triggering
  action          String // e.g. "spawn_agent", "send_notification", "create_task"
  actionPayload   Json? // payload for the action
  enabled         Boolean        @default(true)
  lastRunAt       DateTime?
  lastTriggeredAt DateTime?
  lastStatus      String? // success | failed
  lastError       String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  events          WatcherEvent[]

  @@index([userId, enabled])
  @@index([type])
}

model WatcherEvent {
  id        String   @id @default(cuid())
  watcherId String
  payload   Json? // Context/data when the event occurred
  result    Json? // Output of the action taken
  status    String   @default("pending") // pending | processed | failed
  error     String?
  createdAt DateTime @default(now())
  watcher   Watcher  @relation(fields: [watcherId], references: [id], onDelete: Cascade)

  @@index([watcherId, status])
}

model BrowserSession {
  id            String       @id @default(cuid())
  userId        String
  runId         String?
  projectCellId String?
  externalId    String
  status     String    @default("active") // active | closed | crashed | expired
  currentUrl String?
  title      String?
  metadata   Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  expiresAt     DateTime?

  projectCell   ProjectCell? @relation(fields: [projectCellId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([runId])
}

model Goal {
  id              String        @id @default(cuid())
  userId          String
  title           String
  description     String?
  status          String        @default("active") // active | paused | completed | abandoned
  targetDate      DateTime?
  successCriteria Json?
  strategy        Json?
  nextReviewAt    DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  opportunities   Opportunity[]
  projectCells    ProjectCell[]

  @@index([userId, status])
  @@index([nextReviewAt])
}

model Opportunity {
  id           String    @id @default(cuid())
  userId       String
  goalId       String?
  source       String
  sourceUrl    String?
  title        String
  organization String?
  location     String?
  deadline     DateTime?
  fitScore     Float?
  status       String    @default("found") // found | shortlisted | applied | rejected | interview | won | ignored
  evidence     Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal         Goal?     @relation(fields: [goalId], references: [id], onDelete: SetNull)

  @@unique([userId, sourceUrl])
  @@index([userId, status])
  @@index([goalId])
}

model GmailSyncState {
  id             String    @id @default(cuid())
  userId         String    @unique
  historyId      String?
  watchTopic     String?
  watchExpiresAt DateTime?
  lastSyncedAt   DateTime?
  status         String    @default("not_configured")
  lastError      String?
  updatedAt      DateTime  @updatedAt
}

model CalendarSyncState {
  id               String    @id @default(cuid())
  userId           String    @unique
  calendarId       String    @default("primary")
  syncToken        String?
  channelId        String?
  resourceId       String?
  channelExpiresAt DateTime?
  lastSyncedAt     DateTime?
  status           String    @default("not_configured")
  lastError        String?
  updatedAt        DateTime  @updatedAt
}

model AgentEvent {
  id            String   @id @default(cuid())
  runId         String?
  userId        String
  seq           Int
  type          String // run.created | context.loaded | classified | planned | tool.started | tool.completed | approval.required | approval.resolved | artifact.created | run.completed | run.failed
  level         String   @default("info") // debug | info | warn | error
  message       String
  metadata      Json?
  createdAt     DateTime @default(now())
  projectCellId String?

  run         AgentRun?    @relation(fields: [runId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectCell ProjectCell? @relation(fields: [projectCellId], references: [id], onDelete: Cascade)

  @@unique([runId, seq])
  @@index([userId, createdAt])
  @@index([runId, createdAt])
}

model InboundMessage {
  id          String    @id @default(cuid())
  userId      String?
  channel     String // telegram | dashboard | gmail | calendar | webhook
  externalId  String // Telegram update_id, dashboard UUID, Gmail history id, etc.
  senderId    String?
  text        String?
  payload     Json?
  status      String    @default("received") // received | linked | ignored | run_created | failed
  runId       String?
  receivedAt  DateTime  @default(now())
  processedAt DateTime?
  error       String?

  @@unique([channel, externalId])
  @@index([userId, receivedAt])
}

model ProjectCell {
  id              String   @id @default(cuid())
  userId          String
  goalId          String?
  title           String
  objective       String
  successCriteria Json?
  status          String   @default("active") // active | paused | completed | abandoned
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal      Goal?             @relation(fields: [goalId], references: [id], onDelete: SetNull)
  tasks     ProjectTask[]
  agentRuns AgentRun[]
  artifacts Artifact[]
  approvals       ApprovalRequest[]
  events          AgentEvent[]
  memories        MemoryRecord[]
  reports         Report[]
  browserSessions BrowserSession[]

  @@index([userId, status])
  @@index([goalId])
}

model ProjectTask {
  id            String    @id @default(cuid())
  projectCellId String
  title         String
  description   String?
  status        String    @default("pending") // pending | running | blocked | completed | failed
  assignedSkill String?
  dependsOn     String[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  completedAt   DateTime?

  projectCell ProjectCell @relation(fields: [projectCellId], references: [id], onDelete: Cascade)
  skillRuns   SkillRun[]
  qaResults   QaResult[]
  agentRuns   AgentRun[]
  artifacts   Artifact[]

  @@index([projectCellId, status])
}

model Report {
  id            String   @id @default(cuid())
  userId        String
  projectCellId String?
  type          String // morning | evening | urgent | ad_hoc
  title         String
  content       String?
  payload       Json?
  status        String   @default("generated") // generated | sent | read
  createdAt     DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectCell ProjectCell? @relation(fields: [projectCellId], references: [id], onDelete: SetNull)

  @@index([userId, type])
  @@index([createdAt])
}

model Skill {
  id           String   @id @default(cuid())
  name         String
  description  String
  versionHash  String
  instructions String
  schema       Json?
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  skillRuns SkillRun[]

  @@unique([name])
}

model SkillRun {
  id            String    @id @default(cuid())
  skillId       String
  projectTaskId String?
  agentRunId    String?
  status        String    @default("running") // running | completed | failed
  input         Json?
  output        Json?
  error         String?
  createdAt     DateTime  @default(now())
  completedAt   DateTime?

  skill       Skill        @relation(fields: [skillId], references: [id], onDelete: Cascade)
  projectTask ProjectTask? @relation(fields: [projectTaskId], references: [id], onDelete: SetNull)
  agentRun    AgentRun?    @relation(fields: [agentRunId], references: [id], onDelete: Cascade)

  @@index([skillId, status])
}

model QaResult {
  id            String   @id @default(cuid())
  projectTaskId String
  agentRunId    String?
  passed        Boolean
  feedback      String?
  issues        Json?
  createdAt     DateTime @default(now())

  projectTask ProjectTask @relation(fields: [projectTaskId], references: [id], onDelete: Cascade)
  agentRun    AgentRun?   @relation(fields: [agentRunId], references: [id], onDelete: SetNull)
}

model MemoryRecord {
  id             String   @id @default(cuid())
  userId         String
  projectCellId  String?
  type           String // fact | preference | instruction | summary
  content        String
  confidence     Float    @default(1.0)
  status         String   @default("proposed") // proposed | trusted | rejected | superseded
  supersededById String?
  sourceRunId    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectCell ProjectCell? @relation(fields: [projectCellId], references: [id], onDelete: SetNull)
  sourceRun   AgentRun?    @relation(fields: [sourceRunId], references: [id], onDelete: SetNull)

  supersededBy MemoryRecord?  @relation("Supersession", fields: [supersededById], references: [id], onDelete: SetNull)
  supersedes   MemoryRecord[] @relation("Supersession")

  @@index([userId, status, type])
}
