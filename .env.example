# ╔══════════════════════════════════════════════════════════╗
# ║  Calmant — Your Personal AI Company                     ║
# ║  Copy to .env and fill in your values                   ║
# ╚══════════════════════════════════════════════════════════╝

# ── REQUIRED ──────────────────────────────────────────────

# Better Auth (generate: openssl rand -base64 32)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Database — Neon free tier (https://neon.tech)
DATABASE_URL=

# AI — OpenRouter free models (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# AI — Gemini fallback (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL_FAST=gemini-2.5-flash

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── RECOMMENDED ───────────────────────────────────────────

# Email — Resend free 100/day (https://resend.com)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
USER_EMAIL=

# Telegram Bot (create via @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
# Webhook URL for production (e.g. https://yourdomain.com/api/telegram/webhook)
TELEGRAM_WEBHOOK_URL=
# Secret to validate incoming webhook requests
TELEGRAM_WEBHOOK_SECRET=

# Voice transcription — Groq free (https://console.groq.com)
GROQ_API_KEY=

# Redis — required for BullMQ job queues
REDIS_URL=redis://localhost:6379

# ── OPTIONAL ──────────────────────────────────────────────

# Browser sandbox (Docker container)
SANDBOX_URL=http://sandbox:4000

# Hermes agency backend (Docker service or local FastAPI wrapper)
HERMES_AGENT_URL=http://hermes:8000
HERMES_INTERNAL_API_SECRET=

# Local Ollama Fallback (if running Ollama separately)
OLLAMA_URL=http://localhost:11434
FORCE_LOCAL_LLM=false

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Push notifications
# NTFY_BASE_URL=https://ntfy.sh

# Widget authentication
# WIDGET_API_KEY=

# Web search / scraping (optional, used by agent tools)
# TAVILY_API_KEY=
# FIRECRAWL_API_KEY=

# WhatsApp Meta API
# WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_ID=
